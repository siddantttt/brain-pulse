# Brain Pulse — environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ─── Supabase ───────────────────────────────────────────────────────────────
# Find these in your Supabase project:
#   https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
#
# "Project URL" → VITE_SUPABASE_URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# "anon / public" key under "Project API keys" → VITE_SUPABASE_ANON_KEY
# This key is safe to expose in the browser — it is protected by Row Level Security.
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
